generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id           String   @id @default(uuid())
  roomId       String   @unique
  passwordHash String
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Recording {
  id        String   @id @default(uuid())
  roomId    String
  meetingId String
  createdBy String?
  participants String?
  duration  Int?
  fileSize  Int?
  s3Key     String?
  signedUrl String?
  status        String   // 'processing', 'completed', 'failed'
  failureReason String?
  downloadCount Int      @default(0)
  downloadExpiresAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

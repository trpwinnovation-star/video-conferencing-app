generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                     String   @id @default(uuid())
  email                  String   @unique
  password               String
  name                   String
  role                   Role     @default(USER)
  meetingDefaultPassword String   @default("1234")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  auditId                String?
  auditCode              String?

  scheduledMeetings ScheduledMeeting[] @relation("HostedMeetings")
  meetingAttendees  MeetingAttendee[]
  notifications     Notification[]

  @@unique([auditId, auditCode])
}


model Room {
  id           String   @id @default(uuid())
  roomId       String   @unique
  passwordHash String
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Recording {
  id                String    @id @default(uuid())
  roomId            String
  meetingId         String
  createdBy         String?
  participants      String?
  duration          Int?
  fileSize          Int?
  s3Key             String?
  signedUrl         String?
  status            String // 'processing', 'completed', 'failed'
  failureReason     String?
  downloadCount     Int       @default(0)
  downloadExpiresAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([roomId])
  @@index([meetingId])
  @@index([status])
}

model ScheduledMeeting {
  id          String  @id @default(uuid())
  title       String
  description String?
  roomId      String  @unique
  hostId      String
  host        User    @relation("HostedMeetings", fields: [hostId], references: [id], onDelete: Cascade)

  scheduledTime   DateTime
  durationMinutes Int      @default(60)

  status String @default("scheduled") // 'scheduled', 'in_progress', 'completed', 'cancelled'

  shareableLink String @unique
  meetingCode   String @unique

  attendees MeetingAttendee[]

  hostJoinedAt    DateTime?
  actualStartTime DateTime?
  actualEndTime   DateTime?

  auditVisit String?
  auditCode  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([auditVisit, auditCode])
}

model MeetingAttendee {
  id        String           @id @default(uuid())
  meetingId String
  meeting   ScheduledMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  email String?
  name  String?

  joinedAt DateTime?
  leftAt   DateTime?

  invitationSent Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             String
  title            String
  message          String
  relatedMeetingId String?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

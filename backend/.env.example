PORT=3001
# Exact frontend URL (no trailing slash), required for production CORS + cookies
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-me
DATABASE_URL=postgresql://user:pass@localhost:5432/video_app
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=http://localhost:7880

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# Optional dev aliases (used when AWS_* vars are unset)
# DEV_AWS_REGION=ap-south-1
# DEV_AWS_ACCESS_KEY_ID=
# DEV_AWS_SECRET_ACCESS_KEY=
# DEV_AWS_BUCKET_NAME=

# For MinIO or S3-compatible storage, uncomment:
# AWS_ENDPOINT=http://127.0.0.1:9000
# AWS_FORCE_PATH_STYLE=true

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

